# Qdrant 向量数据库
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 嵌入模型
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# LLM API 配置（用于父块摘要生成，可选）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini

# 文档切块配置
CHILD_CHUNK_SIZE=500
CHILD_CHUNK_OVERLAP=50
CHILD_CHUNKS_PER_PARENT=5

# 检索配置
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
TOP_K_CHAPTERS=3
TOP_K_PARENTS=5
TOP_K_CHILDREN=10

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000