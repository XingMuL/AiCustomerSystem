QDRANT_HOST=localhost
QDRANT_PORT=6333
EMBEDDING_MODEL=./backend/bge-large-zh-v1.5
EMBEDDING_BATCH_SIZE=128

# DeepSeek API 配置
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-d05b323874a8497b91360a8a68ae42b7
LLM_MODEL=deepseek-chat

# RAG 配置
CHILD_CHUNK_SIZE=600
CHILD_CHUNK_OVERLAP=100
CHILD_CHUNKS_PER_PARENT=6
TOP_K_CHAPTERS=5
HYBRID_RECALL_K=20
RERANK_TOP_K=5
ENABLE_QUERY_REWRITE=true
ENABLE_RERANK=true
API_HOST=0.0.0.0
API_PORT=8000

# 文档清洗配置（使用 DeepSeek）
ENABLE_LLM_CLEANING=true
CONVERT_TO_MARKDOWN_FIRST=true
CLEANING_MODEL=deepseek-chat
CLEANING_TEMPERATURE=0.1
CLEANING_MAX_TOKENS=4096

# 降级策略配置
ENABLE_REFLECTION=true
CIRCUIT_BREAKER_FAIL_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=30
LLM_TIMEOUT=30